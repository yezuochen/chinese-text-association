# L3 LLM — GraphRAG chat calls via NVIDIA NIM (free, 40 RPM)
NIM_API_KEY=nvapi-...
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=deepseek-ai/deepseek-v3

# L3 embeddings — GraphRAG internal embed calls via OpenAI (~US$0.05 for 100 files)
# We route here instead of NIM to sidestep the fnllm `encoding_format: null` bug.
OPENAI_API_KEY=sk-...
OPENAI_EMBED_MODEL=text-embedding-3-small